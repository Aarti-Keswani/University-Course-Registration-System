<!DOCTYPE html>
<html>

<head>

<title>Edit Department</title>

<link rel="stylesheet" href="/style.css">

</head>

<body>

<div class="container">

<h1>Edit Department</h1>

<form
action="/departments/update/<%= department.department_id %>"
method="POST">

<label>Department Name</label>

<input
type="text"
name="department_name"
value="<%= department.department_name %>"
required>

<br><br>

<button>

Update Department

</button>

</form>

<br>

<a href="/departments">

<button>Back</button>

</a>

</div>

</body>

</html>